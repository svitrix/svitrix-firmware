root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{cpp,h,c,hpp}]
indent_size = 4

[*.go]
indent_style = tab

[*.{json,yml,yaml,toml}]
indent_size = 2

[*.{ts,tsx,js,jsx,css,html,vue,svelte}]
indent_size = 2

[*.csv]
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.ini]
indent_size = 4

[Makefile]
indent_style = tab
